{
  "name": "speclyn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "description": "AI-powered autonomous testing platform",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @speclyn/db generate",
    "db:migrate": "pnpm --filter @speclyn/db migrate",
    "db:studio": "pnpm --filter @speclyn/db drizzle-kit studio",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "prettier": "^3.5.3",
    "@types/node": "^22.15.21"
  }
}
